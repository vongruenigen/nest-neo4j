{
    "compilerOptions": {
      "module": "commonjs",
      "declaration": true,
      "noImplicitAny": false,
      "removeComments": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "allowSyntheticDefaultImports": true,
      "target": "es2022",
      "lib": [ "es2022" ],
      "sourceMap": false,
      "outDir": "./dist",
      "incremental": true,
      "esModuleInterop": true,
      "skipLibCheck": true
    }
  }